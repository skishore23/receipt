#!/bin/sh
set -eu

SCRIPT_PATH="$0"
while [ -L "${SCRIPT_PATH}" ]; do
  TARGET_PATH="$(readlink "${SCRIPT_PATH}")"
  case "${TARGET_PATH}" in
    /*) SCRIPT_PATH="${TARGET_PATH}" ;;
    *)
      LINK_DIR="$(CDPATH= cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
      SCRIPT_PATH="${LINK_DIR}/${TARGET_PATH}"
      ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
ROOT="${RECEIPT_ROOT:-$(CDPATH= cd -- "${SCRIPT_DIR}/../.." && pwd)}"

DATA_DIR="${DATA_DIR:-${ROOT}/.receipt/data}"
RECEIPT_DATA_DIR="${RECEIPT_DATA_DIR:-${DATA_DIR}}"
export DATA_DIR RECEIPT_DATA_DIR

if [ -n "${RECEIPT_BUN_BIN:-}" ]; then
  BUN_BIN="${RECEIPT_BUN_BIN}"
else
  BUN_BIN="$(command -v bun 2>/dev/null || true)"
  if [ -z "${BUN_BIN}" ] && [ -n "${HOME:-}" ] && [ -x "${HOME}/.bun/bin/bun" ]; then
    BUN_BIN="${HOME}/.bun/bin/bun"
  fi
fi

if [ -z "${BUN_BIN}" ]; then
  echo "receipt: bun is not available on PATH" >&2
  exit 127
fi

exec "${BUN_BIN}" "${ROOT}/src/cli.ts" "$@"
