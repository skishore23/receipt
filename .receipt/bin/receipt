#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/../.." && pwd)"

DATA_DIR="${DATA_DIR:-${ROOT}/.receipt/data}"
RECEIPT_DATA_DIR="${RECEIPT_DATA_DIR:-${DATA_DIR}}"
export DATA_DIR RECEIPT_DATA_DIR

if [ -n "${RECEIPT_BUN_BIN:-}" ]; then
  BUN_BIN="${RECEIPT_BUN_BIN}"
else
  BUN_BIN="$(command -v bun 2>/dev/null || true)"
fi

if [ -z "${BUN_BIN}" ]; then
  echo "receipt: bun is not available on PATH" >&2
  exit 127
fi

exec "${BUN_BIN}" "${ROOT}/src/cli.ts" "$@"
