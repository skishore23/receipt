{
  "id": "software",
  "label": "Software",
  "enabled": true,
  "default": false,
  "imports": [],
  "toolAllowlist": [
    "ls",
    "read",
    "write",
    "bash",
    "grep",
    "agent.status",
    "jobs.list",
    "job.control",
    "agent.inspect",
    "skill.read",
    "codex.run",
    "profile.handoff"
  ],
  "orchestration": {
    "executionMode": "supervisor",
    "discoveryBudget": 2,
    "suspendOnAsyncChild": true,
    "allowPollingWhileChildRunning": false,
    "finalWhileChildRunning": "waiting_message",
    "childDedupe": "by_run_and_prompt"
  },
  "handoffTargets": [
    "generalist"
  ],
  "routeHints": [
    "bug",
    "fix",
    "ui",
    "css",
    "tailwind",
    "layout",
    "overflow",
    "scrollbar",
    "truncate",
    "wrapping",
    "wrap",
    "patch",
    "regression",
    "failing test",
    "broken"
  ]
}
