{
  "name": "receipt",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "bin": {
    "receipt": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "css:build": "bunx @tailwindcss/cli -i src/styles/factory.css -o dist/assets/factory.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i src/styles/factory.css -o dist/assets/factory.css --watch",
    "dev": "bun run css:build && bun --watch src/server.ts",
    "cli": "bun src/cli.ts",
    "receipt": "bun src/cli.ts",
    "factory": "bun src/cli.ts factory",
    "video:capture": "npm --prefix video run capture:ui",
    "video:preview": "npm --prefix video run preview",
    "video:render": "npm --prefix video run render",
    "video:render:vertical": "npm --prefix video run render:vertical",
    "start": "bun dist/server.js",
    "clean": "bun -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "bun run clean && tsc -p tsconfig.json && bun scripts/copy-runtime-assets.mjs && bun run css:build",
    "new:agent": "bun src/cli.ts new",
    "test:smoke": "bun test ./tests/smoke",
    "test:perf": "bun test ./tests/perf",
    "check:no-any": "if rg -n \"as any\\\\b|<any>|:\\\\s*any\\\\b|Runtime<any\\\\s*,\" src/core src/engine src/agents tests; then echo \"explicit any found\"; exit 1; fi",
    "verify": "bun run build && bun run check:no-any && bun run test:smoke"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@hono/zod-validator": "^0.7.6",
    "@inkjs/ui": "^2.0.0",
    "@oblivionocean/minigfm": "^1.0.7",
    "@tailwindcss/cli": "^4.2.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.4",
    "htmx.org": "^2.0.8",
    "ink": "^6.8.0",
    "openai": "^6.16.0",
    "react": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.6.0"
  }
}
